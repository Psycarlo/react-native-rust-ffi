{
  "name": "react-native-rust-ffi",
  "version": "0.1.0",
  "source": "./src/index.tsx",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/src/index.d.ts",
  "exports": {
    "./app.plugin.js": "./app.plugin.js",
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "description": "React Native Rust FFI test bindings",
  "homepage": "https://github.com/Psycarlo/react-native-rust-ffi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Psycarlo/react-native-rust-ffi.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "app.plugin.js",
    "react-native.config.js",
    "scripts",
    "!scripts/patch-bindings.sh",
    "plugin",
    "!plugin/src",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "LICENSE"
  ],
  "scripts": {
    "ubrn:ios": "ubrn build ios --release --config ubrn.config.yaml --and-generate",
    "ubrn:android": "ubrn build android --release --config ubrn.config.yaml --and-generate",
    "prepare": "bob build",
    "plugin:build": "EXPO_NONINTERACTIVE=true expo-module build plugin",
    "plugin:build:win": "tsc --project plugin/tsconfig.json",
    "typecheck": "tsc"
  },
  "author": {
    "name": "Psycarlo",
    "url": "https://psycarlo.com"
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "0.30.0-1"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@expo/config-plugins": "^55.0.6",
    "@react-native-community/cli": "^18.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "expo-module-scripts": "^55.0.2",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "typescript": "^5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "rust_modules/**",
    "targets": [
      "codegen",
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNRustFFIReactNativeSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    },
    "android": {
      "javaPackageName": "com.reactnativerustffi"
    },
    "includesGeneratedCode": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "cpp",
    "version": "0.49.0"
  }
}
